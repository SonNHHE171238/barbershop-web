PORT=3000
# Must match the Vite dev origin (see front-end); required for cookie + CORS
CLIENT_URL=http://localhost:5173

# Required for login / refresh / getMe
MONGO_URI=mongodb://localhost:27017/barbershop

# Required — use long random strings in real deployments (not the placeholders below)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Optional token lifetimes (passed to jsonwebtoken; cookie maxAge follows the same values)
# Examples: 15m, 1h, 7d
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Registration OTP (dev: printed to server console; set to 0 or false to disable logging)
LOG_OTP_TO_CONSOLE=true
OTP_EXPIRES_MINUTES=10
